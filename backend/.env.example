# Flask
FLASK_APP=src/api/app.py
FLASK_ENV=development
PORT=5001
SECRET_KEY=change-this-in-production
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,http://localhost:5173,http://127.0.0.1:5173
MAX_CONTENT_LENGTH_MB=10

# MongoDB
MONGODB_URI=mongodb+srv://attendance_user:Atten23Secure@cluster0.0aybluq.mongodb.net/attendance_db?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=attendance_db
USE_MOCK_DB=false
ALLOW_MOCK_DB=false

# Recognition
MODEL_PATH=../persistent/models/face_encodings.pkl
DATASET_PATH=../persistent/dataset
MANUAL_REQUESTS_IMAGE_DIR=../persistent/manual_requests
CAMERA_INDEX=0
RECOGNITION_TOLERANCE=0.5
FRAME_RESIZE_SCALE=0.25
PROCESS_EVERY_N_FRAMES=2
FACE_DETECTION_MODEL=hog
FACE_UPSAMPLE_TIMES=0
DISPLAY_PREVIEW=false

# Liveness / anti-spoofing
ENABLE_LIVENESS=true
SCAN_REQUIRE_BLINK=true
SCAN_REQUIRED_BLINK_COUNT=1
SCAN_RESIZE_WIDTH=420
SCAN_FACE_UPSAMPLE_TIMES=0
SCAN_MIN_FACE_AREA_RATIO=0.03
SCAN_EDGE_MARGIN_RATIO=0.02
SCAN_CHALLENGE_TTL_SECONDS=18
LIVENESS_BLINK_CONSEC_FRAMES=2
LIVENESS_MOVEMENT_MIN_PIXELS=3
LIVENESS_MIN_LAPLACIAN_VAR=55

# Fast training
TRAIN_IMAGE_MAX_WIDTH=800
TRAIN_NUM_JITTERS=1
TRAIN_ENCODING_MODEL=small
TRAIN_MAX_WORKERS=0

# Admin dashboard login (demo defaults, change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Optional global fallback (minutes)
JWT_EXPIRES_MIN=10080
# Optional role-specific overrides (minutes)
JWT_ADMIN_EXPIRES_MIN=10080
JWT_USER_EXPIRES_MIN=10080
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_MIX=true
# Allow admin to create users without face images (keep false in production)
ALLOW_CREDENTIALS_ONLY_ENROLLMENT=false

# Office geofence for attendance scanning
ENABLE_OFFICE_GEOFENCE=true
FORCE_OFFICE_GEOFENCE=false
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_METERS=500
