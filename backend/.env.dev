# Development defaults (safe for local use)
APP_ENV=dev
FLASK_APP=src/api/app.py
FLASK_ENV=development
PORT=5001

SECRET_KEY=dev-secret-change-me
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,http://localhost:5173,http://127.0.0.1:5173
MAX_CONTENT_LENGTH_MB=10
DISABLE_BACKEND_UI=true
FRONTEND_APP_BASE_URL=http://127.0.0.1:5173

# Fast scan profile (dev)
ENABLE_LIVENESS=true
SCAN_REQUIRE_BLINK=true
SCAN_REQUIRED_BLINK_COUNT=1
SCAN_MIN_DURATION_SECONDS=2.0
SCAN_RESIZE_WIDTH=320
SCAN_FACE_UPSAMPLE_TIMES=0
SCAN_MIN_FACE_AREA_RATIO=0.02
SCAN_EDGE_MARGIN_RATIO=0.01
LIVENESS_BLINK_CONSEC_FRAMES=1
LIVENESS_MOVEMENT_MIN_PIXELS=3
LIVENESS_MOVEMENT_MIN_FRAMES=4
LIVENESS_MOVEMENT_MIN_SPAN_PIXELS=8
LIVENESS_MIN_LAPLACIAN_VAR=12

MONGODB_URI=mongodb+srv://attendance_user:Atten23Secure@cluster0.0aybluq.mongodb.net/attendance_db?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=attendance_db
USE_MOCK_DB=false
ALLOW_MOCK_DB=false

MODEL_PATH=../persistent/models/face_encodings.pkl
DATASET_PATH=../persistent/dataset
MANUAL_REQUESTS_IMAGE_DIR=../persistent/manual_requests

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Prefer hash in real environments
# ADMIN_PASSWORD_HASH=
JWT_ADMIN_EXPIRES_MIN=10080
JWT_USER_EXPIRES_MIN=10080

# Geofence (dev-safe defaults)
ENABLE_OFFICE_GEOFENCE=false
FORCE_OFFICE_GEOFENCE=false
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_METERS=500

# Allow quick user account creation without face images in dev UI
ALLOW_CREDENTIALS_ONLY_ENROLLMENT=true
